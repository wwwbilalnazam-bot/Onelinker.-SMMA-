# ════════════════════════════════════════════════════════════
# ONELINKER — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://onelinker.ai
NEXT_PUBLIC_APP_NAME=Onelinker

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Outstand API ─────────────────────────────────────────────
# Social media API proxy — handles all platform integrations
# Sign up at: https://outstand.so
OUTSTAND_API_KEY=your-outstand-api-key

# ── Meta Direct API (Facebook + Instagram) ──────────────────
# Use your own Meta developer app instead of Outstand for FB/IG.
# Get from: Meta for Developers → App Dashboard → Settings → Basic
# In development mode, only app roles (admin/developer/tester) can use it.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ── YouTube BYOK (Bring Your Own Key) ───────────────────────
# Register your Google Cloud OAuth credentials for YouTube
# These are registered with Outstand once on setup
# Get from: Google Cloud Console → APIs & Services → Credentials
YOUTUBE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-google-client-secret

# ── Anthropic Claude AI ──────────────────────────────────────
# AI-powered captions, hashtags, content ideas
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ───────────────────────────────────────────────────
# Payments and subscriptions
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — create in Stripe Dashboard
STRIPE_CREATOR_MONTHLY_PRICE_ID=price_...
STRIPE_CREATOR_YEARLY_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_YEARLY_PRICE_ID=price_...

# ── Resend Email ─────────────────────────────────────────────
# Transactional emails
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@onelinker.ai

# ── hCaptcha ─────────────────────────────────────────────────
# Bot protection on signup forms
# Dashboard: https://dashboard.hcaptcha.com/sites
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-site-key
HCAPTCHA_SECRET_KEY=your-secret-key

# ── Upstash Redis (Rate Limiting) ────────────────────────────
# Serverless Redis for API rate limiting
# Dashboard: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── App Secret ───────────────────────────────────────────────
# Random 32-char secret for session signing
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# ── Development Overrides ─────────────────────────────────────
# Uncomment for local development
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
